      "id": "apify-manning",
      "name": "Apify: Manning ZIP 29102",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [400, 880]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.apify.com/v2/acts/johnvc~fuelprices/run-sync-get-dataset-items",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            { "name": "token", "value": "={{$env.APIFY_API_TOKEN}}" },
            { "name": "memory", "value": "128" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\"search\": \"29118\", \"fuel\": 1, \"maxAge\": 0}",
        "options": { "timeout": 130000 }
      },
      "id": "apify-orangeburg",
      "name": "Apify: Orangeburg ZIP 29118",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [400, 1000]
    },
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 8 * * *"
            }
          ]
        }
      },
      "id": "cron-daily-summary",
      "name": "Daily 8AM Summary",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [160, 1160]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{$env.PYTHON_ENGINE_URL || 'https://shorttrip-python-engine.onrender.com'}}/engine/daily-summary",
        "options": {}
      },
      "id": "trigger-daily-summary",
      "name": "Send Daily Email Summary",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [400, 1160]
    },
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "shorttrip-price-check",
        "responseMode": "lastNode",
        "options": {}
      },
      "id": "webhook-alert",
      "name": "Alert Webhook (from Python Engine)",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [160, 1320]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "check-action",
              "leftValue": "={{ $json.action }}",
              "rightValue": "alert",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "check-is-alert",
      "name": "Is Alert?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [400, 1320]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{$env.NODE_API_URL || 'https://shorttrip-node-api.onrender.com'}}/api/alerts/internal",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Content-Type", "value": "application/json" },
            { "name": "x-internal-key", "value": "stGI7f4D2a9B8c3E1f6D0a5B2c9E4f7D1a8B3c6E0f5D9a2B7c4E1f8D3a6B0c5E" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ store_id: $json.store_id, store_name: $json.store_name, our_price: $json.our_price, comp_price: $json.comp_price, comp_name: $json.comp_name, price_diff: $json.price_diff, priority: $json.priority || 'MED', message: $json.message, action: $json.action }) }}",
        "options": {}
      },
      "id": "save-to-dashboard",
      "name": "Save Alert to Dashboard DB",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [660, 1220]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={ \"status\": \"processed\", \"action\": $json.action, \"alert_saved\": true }"
      },
      "id": "respond-webhook",
      "name": "Respond to Webhook",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [900, 1320]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={ \"status\": \"skipped\", \"action\": $json.action }"
      },
      "id": "respond-webhook-skip",
      "name": "Respond (No Alert)",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [660, 1420]
    }
  ],
  "connections": {
    "Every 2 Hours": {
      "main": [[
        { "node": "Step 1: Discover Competitors (OpenStreetMap)", "type": "main", "index": 0 },
        { "node": "Apify: Ridgeville ZIP 29472", "type": "main", "index": 0 },
        { "node": "Apify: Ladson ZIP 29456", "type": "main", "index": 0 },
        { "node": "Apify: Sumter ZIP 29154", "type": "main", "index": 0 },
        { "node": "Apify: Moncks Corner ZIP 29461", "type": "main", "index": 0 },
        { "node": "Apify: Manning ZIP 29102", "type": "main", "index": 0 },
        { "node": "Apify: Orangeburg ZIP 29118", "type": "main", "index": 0 }
      ]]
    },
    "Daily 8AM Summary": {
      "main": [[{ "node": "Send Daily Email Summary", "type": "main", "index": 0 }]]
    },
    "Alert Webhook (from Python Engine)": {
      "main": [[{ "node": "Is Alert?", "type": "main", "index": 0 }]]
    },
    "Is Alert?": {
      "main": [
        [{ "node": "Save Alert to Dashboard DB", "type": "main", "index": 0 }],
        [{ "node": "Respond (No Alert)", "type": "main", "index": 0 }]
      ]
    },
    "Save Alert to Dashboard DB": {
      "main": [[{ "node": "Respond to Webhook", "type": "main", "index": 0 }]]
    }
  },
  "settings": {
    "executionOrder": "v1",
    "saveManualExecutions": true,
    "callerPolicy": "workflowsFromSameOwner",
    "errorWorkflow": ""
  },
  "tags": ["shorttrip", "garudx", "gas-price", "apify"],
  "pinData": {}
}
