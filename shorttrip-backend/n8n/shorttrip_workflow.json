          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\"search\": \"29154\", \"fuel\": 1, \"maxAge\": 0}",
        "options": { "timeout": 130000 }
      },
      "id": "apify-sumter",
      "name": "Apify: Sumter ZIP 29154",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [400, 640]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.apify.com/v2/acts/johnvc~fuelprices/run-sync-get-dataset-items",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
