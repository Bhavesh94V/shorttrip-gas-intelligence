{
  "name": "Short Trip Gas Intelligence (Apify Edition)",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "hours",
              "minutesInterval": 120
            }
          ]
        }
      },
      "id": "cron-price-check",
      "name": "Every 2 Hours",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [160, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{$env.PYTHON_ENGINE_URL || 'https://shorttrip-python-engine.onrender.com'}}/engine/run",
        "options": { "timeout": 300000 }
      },
      "id": "trigger-python-engine",
      "name": "Step 1: Discover Competitors (OpenStreetMap)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [400, 200]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.apify.com/v2/acts/johnvc~fuelprices/run-sync-get-dataset-items",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            { "name": "token", "value": "={{$env.APIFY_API_TOKEN}}" },
            { "name": "memory", "value": "128" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\"search\": \"29472\", \"fuel\": 1, \"maxAge\": 0}",
        "options": { "timeout": 130000 }
      },
      "id": "apify-ridgeville",
      "name": "Apify: Ridgeville ZIP 29472",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [400, 400]
    },
