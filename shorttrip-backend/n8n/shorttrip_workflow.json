      "id": "apify-moncks",
      "name": "Apify: Moncks Corner ZIP 29461",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [400, 760]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.apify.com/v2/acts/johnvc~fuelprices/run-sync-get-dataset-items",
